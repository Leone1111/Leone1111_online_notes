---
import { withBasePath } from "../utils/paths";

interface Props {
  project: {
    id: string;
    data: {
      title: string;
      description: string;
      status?: string;
      category?: string;
      tags: string[];
      github?: string;
      download?: string;
    };
  };
}

const { project } = Astro.props;
const status = project.data.status || "Project";
---

<article class="card pad project-card">
  <div>
    <p class="eyebrow">{status}</p>
    <h3><a href={withBasePath(`/projects/${project.id}`)}>{project.data.title}</a></h3>
    <p>{project.data.description}</p>
    <div class="tag-list">
      {project.data.category && <span class="tag">{project.data.category}</span>}
      {project.data.tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>
  </div>
  <div class="project-actions">
    <a class="button primary" href={withBasePath(`/projects/${project.id}`)}>项目详情</a>
    {project.data.github && <a class="button" href={project.data.github} target="_blank" rel="noreferrer">GitHub</a>}
    {project.data.download && <a class="button" href={project.data.download} target="_blank" rel="noreferrer">资料链接</a>}
  </div>
</article>

<style>
  .project-card {
    display: flex;
    min-height: 100%;
    flex-direction: column;
    justify-content: space-between;
  }

  .project-card h3 {
    margin: 0 0 8px;
    font-size: 1.35rem;
  }

  .project-card p:not(.eyebrow) {
    color: var(--muted);
  }

  .project-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 22px;
  }
</style>
