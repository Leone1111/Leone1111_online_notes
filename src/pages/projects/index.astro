---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import ProjectCard from "@components/ProjectCard.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { withBasePath } from "../../utils/paths";

const projects = (await getCollection("projects"))
  .filter((project) => project.data.visibility === "public")
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const projectDirectory = [
  {
    id: "machine-learning-screening",
    title: "机器学习材料筛选",
    description: "用于整理描述符、模型筛选流程、候选材料排序和后续可解释性分析。",
    href: "/projects/high-entropy-sodium-layered-materials"
  },
  {
    id: "dft-workflow",
    title: "DFT 计算与自动化",
    description: "用于整理 VASP 计算、结果提取、任务检查和科研数据表格生成。",
    href: "/projects/dft-automation-toolkit"
  },
  {
    id: "project-readme",
    title: "项目 README 目录",
    description: "每个项目页面都作为一个 README 使用，集中放背景、技术路线、亮点和外部链接。",
    href: "/projects/high-entropy-sodium-layered-materials"
  }
];
---

<BaseLayout title="Projects | Leone1111" description="科研项目、代码项目和计算材料项目作品集。">
  <section class="container page">
    <SectionHeader
      eyebrow="Projects"
      title="项目作品集"
      description="每个项目都尽量说明研究问题、技术路线、亮点，以及 GitHub 或网盘资料链接。"
    />

    <div class="project-directory card pad">
      <p class="eyebrow">Project Directory</p>
      <h3>项目目录</h3>
      <div class="directory-grid">
        {
          projectDirectory.map((item) => (
            <a id={item.id} class="directory-item" href={withBasePath(item.href)}>
              <strong>{item.title}</strong>
              <span>{item.description}</span>
            </a>
          ))
        }
      </div>
    </div>

    <div class="grid two project-grid">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>
</BaseLayout>

<style>
  .project-directory {
    margin-bottom: 22px;
  }

  .project-directory h3 {
    margin: 0 0 16px;
    font-size: 1.4rem;
  }

  .directory-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .directory-item {
    display: grid;
    gap: 6px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 14px;
    background: var(--surface-soft);
  }

  .directory-item strong {
    color: var(--accent-strong);
  }

  .directory-item span {
    color: var(--muted);
    font-size: 0.92rem;
  }

  .project-grid {
    align-items: stretch;
  }

  @media (max-width: 860px) {
    .directory-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
