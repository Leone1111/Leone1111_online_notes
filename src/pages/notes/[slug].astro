---
import { render } from "astro:content";
import FileDownloadList from "@components/FileDownloadList.astro";
import ContentLayout from "@layouts/ContentLayout.astro";
import { getPublicNotes } from "../../lib/content/publicContent";
import { withBasePath } from "../../utils/paths";

export async function getStaticPaths() {
  const notes = await getPublicNotes();
  return notes.map((note) => ({
    params: { slug: note.id },
    props: { note }
  }));
}

const { note } = Astro.props;
const renderedNote = note.markdownEntry ? await render(note.markdownEntry) : null;
const Content = renderedNote?.Content;
---

<ContentLayout
  title={note.data.title}
  description={note.data.description}
  date={note.data.pubDate}
  tags={note.data.tags}
>
  <div class="button-row content-actions">
    <a class="button" href={withBasePath("/notes")}>返回笔记目录</a>
  </div>
  <FileDownloadList files={note.data.files} />
  {Content ? <Content /> : <div class="supabase-body" set:html={note.data.bodyHtml} />}
</ContentLayout>

<style>
  .content-actions {
    margin: 24px 0;
  }
</style>
