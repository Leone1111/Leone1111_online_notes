---
import { render } from "astro:content";
import FileDownloadList from "@components/FileDownloadList.astro";
import ContentLayout from "@layouts/ContentLayout.astro";
import { getPublicBlogPosts } from "../../lib/content/publicContent";

export async function getStaticPaths() {
  const posts = await getPublicBlogPosts();
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post }
  }));
}

const { post } = Astro.props;
const renderedPost = post.markdownEntry ? await render(post.markdownEntry) : null;
const Content = renderedPost?.Content;
---

<ContentLayout title={post.data.title} description={post.data.description} date={post.data.pubDate} tags={post.data.tags}>
  <FileDownloadList files={post.data.files} />
  {Content ? <Content /> : <div class="supabase-body" set:html={post.data.bodyHtml} />}
</ContentLayout>
